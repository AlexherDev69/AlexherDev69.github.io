---
import { profile, socials } from '../data/portfolio';
---

<section id="top" class="hero">
  <div class="container hero__inner">
    {profile.available && (
      <p class="badge reveal">
        <span class="dot"></span> Disponible pour de nouveaux projets
      </p>
    )}

    <h1 class="hero__title reveal">
      {profile.name}
      <span class="hero__role gradient-text">{profile.role}</span>
    </h1>

    <p class="hero__tagline reveal">{profile.tagline}</p>

    <div class="hero__actions reveal">
      <a href="/projets" class="btn btn-primary">Parcourir mon portfolio</a>
      <a href="#contact" class="btn btn-ghost">Me contacter</a>
    </div>

    <ul class="hero__socials reveal">
      {socials.map((s) => (
        <li>
          <a href={s.url} target="_blank" rel="noopener noreferrer">
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(5rem, 4rem + 8vw, 9rem) var(--space-section);
  }

  .hero__inner {
    max-width: 820px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    font-size: var(--step--1);
    color: var(--muted);
    margin-bottom: 1.6rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-2);
    box-shadow: 0 0 0 0 rgba(45, 212, 191, 0.5);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(45, 212, 191, 0.5); }
    70% { box-shadow: 0 0 0 8px rgba(45, 212, 191, 0); }
    100% { box-shadow: 0 0 0 0 rgba(45, 212, 191, 0); }
  }

  .hero__title {
    font-size: var(--step-4);
    display: flex;
    flex-direction: column;
  }

  .hero__role {
    font-size: 0.62em;
  }

  .hero__tagline {
    margin-top: 1.4rem;
    font-size: var(--step-1);
    color: var(--muted);
    max-width: 55ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }

  .hero__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    list-style: none;
    padding: 0;
    margin-top: 2.6rem;
  }

  .hero__socials a {
    color: var(--muted);
    font-size: var(--step--1);
    font-weight: 500;
    position: relative;
    transition: color 0.2s ease;
  }

  .hero__socials a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.25s ease;
  }

  .hero__socials a:hover {
    color: var(--text-strong);
  }

  .hero__socials a:hover::after {
    width: 100%;
  }

  /* Décalage progressif de l'apparition */
  .reveal:nth-child(1) { transition-delay: 0s; }
  .reveal:nth-child(2) { transition-delay: 0.08s; }
  .reveal:nth-child(3) { transition-delay: 0.16s; }
  .reveal:nth-child(4) { transition-delay: 0.24s; }
  .reveal:nth-child(5) { transition-delay: 0.32s; }
</style>
